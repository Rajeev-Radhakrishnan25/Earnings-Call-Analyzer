# ===== DATABASE =====
# Option 1: Production (Neon) - single connection string
# DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/earnings_call_analyzer?sslmode=require

# Option 2: Local dev (Docker) - individual variables
POSTGRES_USER=eca_user
POSTGRES_PASSWORD=eca_local_dev_password
POSTGRES_DB=earnings_call_analyzer
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ===== API KEYS =====
ANTHROPIC_API_KEY=sk-ant-your-key-here
EDGAR_USER_AGENT=YourName your.email@example.com

# ===== EMBEDDING =====
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ===== APP =====
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# ===== FRONTEND (production only) =====
# FRONTEND_URL=https://your-app.vercel.app
